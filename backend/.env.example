# Proxmox API
PROXMOX_HOST=10.0.0.10
PROXMOX_PORT=8006
PROXMOX_TOKEN_ID=monitoring@pve!monitoring
PROXMOX_TOKEN_SECRET=your-token-secret-here
PROXMOX_VERIFY_SSL=false

# K3s Kubernetes
K3S_API_SERVER=https://10.0.1.10:6443
K3S_KUBECONFIG_PATH=~/.kube/config

# SSH Configuration
SSH_USER=root
SSH_KEY_PATH=~/.ssh/id_ed25519
SSH_KNOWN_HOSTS_PATH=~/.ssh/known_hosts

# Build Server
BUILD_SERVER_HOST=10.0.2.10
BUILD_SERVER_USER=admin
BUILD_SERVER_PORT=22
PROJECTS_BASE_PATH=/home/admin/projects

# Agent Timeouts
AGENT_TIMEOUT=600

# Server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Discord notifications (leave empty to disable)
DISCORD_WEBHOOK_URL=

# Authentication (leave empty to disable)
API_KEY=
