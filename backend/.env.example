K3S_KUBECONFIG_PATH=~/.kube/config

# SSH Configuration
SSH_USER=root
SSH_KEY_PATH=~/.ssh/id_ed25519

# Server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173
